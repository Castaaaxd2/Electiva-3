{
  "expo": {
    "name": "BirdLens",
    "slug": "mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3EE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.birdlens.app",
      "infoPlist": {
        "NSCameraUsageDescription": "BirdLens usa la cámara para fotografiar aves e identificar su especie.",
        "NSPhotoLibraryUsageDescription": "BirdLens accede a tu galería para identificar aves desde fotos existentes.",
        "NSPhotoLibraryAddUsageDescription": "BirdLens puede guardar fotos de aves en tu galería."
      }
    },
    "android": {
      "package": "com.birdlens.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F7F3EE"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "BirdLens accede a tu galería para identificar aves desde fotos existentes.",
          "cameraPermission": "BirdLens usa la cámara para fotografiar aves e identificar su especie.",
          "savePhotosPermission": "BirdLens puede guardar fotos de aves en tu galería."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "da24855b-aaa2-454e-aeb8-8f24389e0edc"
      }
    },
    "owner": "castaaaxd"
  }
}
